# GitHub Personal Access Token (required)
# Scope: repo (for private repos) or public_repo (public only)
GITHUB_TOKEN=your_github_pat_here

# Dashboard password (required)
# Used for shared password authentication
DASHBOARD_PASSWORD=your_password_here

# Cookie signing secret (required)
# Must be a random value different from DASHBOARD_PASSWORD
DASHBOARD_COOKIE_SECRET=your_random_secret_here
