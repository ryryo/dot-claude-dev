# GitHub Personal Access Token (必須)
# スコープ: repo (プライベートリポジトリも扱う場合) または public_repo (公開のみ)
GITHUB_TOKEN=your_github_pat_here

# ダッシュボードのパスワード (必須)
# 共有パスワード認証で利用
DASHBOARD_PASSWORD=your_password_here

# Cookie 署名用シークレット (必須)
# DASHBOARD_PASSWORD とは別のランダム値にすること
DASHBOARD_COOKIE_SECRET=your_random_secret_here

