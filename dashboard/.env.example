# GitHub Personal Access Token (必須)
# スコープ: repo (プライベートリポジトリも扱う場合) または public_repo (公開のみ)
GITHUB_TOKEN=your_github_pat_here

# ダッシュボードのパスワード (必須)
# 共有パスワード認証で利用
DASHBOARD_PASSWORD=your_password_here

# Cookie 署名用シークレット (必須)
# DASHBOARD_PASSWORD とは別のランダム値にすること
DASHBOARD_COOKIE_SECRET=your_random_secret_here

# Claude Code Web セッション起動用 Routines API トリガー ID (必須: FAB 機能を使う場合)
# claude.ai/code/routines で作成したルーチンの「API トリガー」発行時に表示される trig_... の値
ANTHROPIC_ROUTINE_TRIGGER_ID=trig_your_trigger_id_here

# Routines API トリガーのアクセストークン (必須: FAB 機能を使う場合)
# トリガー発行時に 1 度だけ表示される sk-ant-oat01-... の値。再表示不可なので控えておくこと
ANTHROPIC_ROUTINE_TOKEN=sk-ant-oat01-your_token_here
