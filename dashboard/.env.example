# GitHub Personal Access Token (必須)
# スコープ: repo (プライベートリポジトリも扱う場合) または public_repo (公開のみ)
GITHUB_TOKEN=your_github_pat_here

# ダッシュボードのパスワード (必須)
# 共有パスワード認証で利用
DASHBOARD_PASSWORD=your_password_here

# Cookie 署名用シークレット (必須)
# DASHBOARD_PASSWORD とは別のランダム値にすること
DASHBOARD_COOKIE_SECRET=your_random_secret_here

# Claude Web Trigger (claude.ai 内部 API 直叩き用) -------------------------------
# /refresh-claude-web-cookie スキルで Chrome から自動抽出・更新できる
# sessionKey は HttpOnly Cookie（sk-ant-sid02-... 131 chars）
CLAUDE_SESSION_KEY=sk-ant-sid02-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# claude.ai の Organization UUID（Web UI で x-organization-uuid ヘッダーに常時付与される値）
CLAUDE_ORG_UUID=72f15ec8-6c9f-4c94-9014-5021153382bb

# claude.ai Default Environment ID（POST /v1/sessions の environment_id）
CLAUDE_ENV_ID=env_01RqJFrxgn6poGNpyCTFWHh5
